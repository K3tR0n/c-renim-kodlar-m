#include <iostream>
using namespace std;

class Mezun
{
private:
    float vize;
    float final;

public:

    void setVize(float vizep)
    {
        if(vizep < 0)
            vize = 0;
        else
            vize = vizep;
    }

    void setFinal(float finalp)
    {
        if(finalp < 0)
            final = 0;
        else
            final = finalp;
    }

    float hesapla()
    {
        float sonuc = (vize * 0.40) + (final * 0.60);
        return sonuc;
    }

    string harfNotu()
    {
        float sonuc = hesapla();

        if(sonuc >= 90)
            return "AA";
        else if(sonuc >= 85)
            return "BA";
        else if(sonuc >= 80)
            return "BB";
        else if(sonuc >= 70)
            return "CB";
        else if(sonuc >= 60)
            return "CC";
        else if(sonuc >= 50)
            return "DC";
        else
            return "FF";
    }
};

int main()
{
    Mezun ogrenci;

    float vize;
    float final;

    cout << "Vize notunuzu giriniz: ";
    cin >> vize;

    cout << "Final notunuzu giriniz: ";
    cin >> final;

    ogrenci.setVize(vize);
    ogrenci.setFinal(final);

    float ortalama = ogrenci.hesapla();

    cout << "Ortalama: " << ortalama << endl;
    cout << "Harf Notu: " << ogrenci.harfNotu() << endl;

    return 0;
}
